# Google Places API (New)
# 1) Gere a API Key no Google Cloud com Places API habilitada.
# 2) Defina o Place ID do perfil da empresa no Google Maps.
# 3) Opcional: use um endpoint backend/proxy para esconder a chave.

VITE_GOOGLE_PLACE_ID=SEU_PLACE_ID_AQUI
VITE_GOOGLE_PLACES_API_KEY=SUA_API_KEY_AQUI

# Opcional: se informar este endpoint, ele tem prioridade sobre Place ID + API Key
# Exemplo de retorno esperado:
# {
#   "googleMapsUri": "https://maps.google.com/...",
#   "reviews": [
#     {
#       "name": "review-id",
#       "rating": 5,
#       "relativePublishTimeDescription": "há 2 semanas",
#       "text": { "text": "Ótimo atendimento" },
#       "authorAttribution": {
#         "displayName": "Cliente",
#         "uri": "https://maps.google.com/..."
#       }
#     }
#   ]
# }
# VITE_GOOGLE_REVIEWS_ENDPOINT=https://seu-endpoint.com/reviews
